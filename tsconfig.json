{
  "compilerOptions": {
    "target": "esnext",
    // 1. Thay "node" bằng "bundler" để hỗ trợ các công cụ build hiện đại
    "moduleResolution": "bundler", 
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "declaration": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true, // Thường đi kèm với bundler
    "module": "esnext",
    "noEmit": true, // Thường dùng khi có bundler bên ngoài xử lý file
    "paths": {
      "@/*": ["./src/*"],
      "@@/*": ["./src/.umi/*"],
      "@@test/*": ["./src/.umi-test/*"]
    }
  },
  "include": ["./**/*.d.ts", "./**/*.ts", "./**/*.tsx"]
}