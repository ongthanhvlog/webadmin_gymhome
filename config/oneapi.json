              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "createdAt",
            "in": "query",
            "description": "Ngày tạo",
            "schema": {
              "type": "string",
              "format": "datetime"
            }
          },
          {
            "name": "updatedAt",
            "in": "query",
            "description": "Ngày cập nhật",
            "schema": {
              "type": "string",
              "format": "datetime"
            }
          },
          {
            "name": "progress",
            "in": "query",
            "description": "Tiến độ",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
